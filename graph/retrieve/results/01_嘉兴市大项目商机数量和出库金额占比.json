  "subgraph": {
    "nodes": [
      {
        "label": "金额指标",
        "type": "MetricCategory",
        "color": "#60a5fa",
        "description": "金额类指标的逻辑分组（商机金额、总商机金额、去重商机金额、出库金额）"
      },
      {
        "label": "占比",
        "type": "Function",
        "color": "#ca60fb",
        "description": "占总体比例",
        "category": "对比分析"
      },
      {
        "label": "出库明细",
        "type": "Entity",
        "color": "#60a5fa",
        "description": "近六年_日出库明细（无参数）_客户_GN分析立方体",
        "cube": "cube_gn_sales_deliver_detail",
        "dataset": "ads_gn_sales_deliver_detail",
        "foreign_entity": "opportunity_id"
      },
      {
        "label": "求和",
        "type": "Function",
        "color": "#ca60fb",
        "description": "SUM",
        "category": "基础聚合"
      },
      {
        "label": "出库金额",
        "type": "Metric",
        "color": "#fb6060",
        "description": "交货总金额，来自出库明细域",
        "cube": "cube_gn_sales_deliver_detail",
        "metric": "metric_delivery_amount_total",
        "metric_type": "simple",
        "agg": "SUM",
        "expr": "ZJHZJ_JT"
      },
      {
        "label": "商机",
        "type": "Entity",
        "color": "#60a5fa",
        "description": "历年至今_商机明细（未绑参数）_报备城市维度",
        "cube": "cube_kpi_opportunity",
        "dataset": "ads_kpi_opportunity",
        "primary_entity": "opportunity_id"
      },
      {
        "label": "规上商机",
        "type": "Concept/Filter",
        "color": "#7afb60",
        "description": "出库额10万以上的规上商机",
        "expr": "metric_outbound_amount_sum_alias >= 10",
        "filter": "filter_opportunity_scale_above_10w",
        "filter_type": "Metric"
      },
      {
        "label": "商机数",
        "type": "Metric",
        "color": "#fb6060",
        "description": "商机总数，按商机编号去重计数",
        "cube": "cube_kpi_opportunity",
        "metric": "metric_outbound_opportunity_count",
        "metric_type": "simple",
        "agg": "COUNT_DISTINCT",
        "expr": "ZZOPPID"
      },
      {
        "label": "数量指标",
        "type": "MetricCategory",
        "color": "#60a5fa",
        "description": "数量类指标的逻辑分组（商机数、去重商机数、重复商机数）"
      },
      {
        "label": "首次出库",
        "type": "Event",
        "color": "#f8fb60",
        "description": "第一次出库日期",
        "cube": "cube_kpi_opportunity",
        "dimension": "dim_first_outbound_date",
        "column": "first_outbound_date",
        "data_type": "datetime"
      },
      {
        "label": "去重商机数",
        "type": "Metric",
        "color": "#fb6060",
        "description": "去重后的商机数，语义层暂无对应 metric 文件，建议补充",
        "depends_on": [
          "metric_outbound_opportunity_count",
          "metric_duplicate_opportunity_count"
        ],
        "warning": "语义层缺少对应 metric 定义"
      },
      {
        "label": "计数",
        "type": "Function",
        "color": "#ca60fb",
        "description": "COUNT / COUNT_DISTINCT",
        "category": "基础聚合"
      },
      {
        "label": "城市",
